{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "paths": {
      "@cargohub/shared": ["./src/shared/src"],
      "@cargohub/shared/*": ["./src/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "./src/shared" }
  ]
}
