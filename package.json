{
  "name": "cargohub",
  "version": "1.0.0",
  "private": true,
  "description": "CargoHub — Cross-platform cargo logistics platform",
  "workspaces": [
    "frontend/*",
    "backend",
    "backend/src/shared",
    "mobile-app/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:customer\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:customer": "npm run dev --workspace=frontend/customer-portal",
    "dev:admin": "npm run dev --workspace=frontend/admin-dashboard",
    "dev:b2b": "npm run dev --workspace=frontend/b2b-portal",
    "dev:driver": "npm run start --workspace=driver-app",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
